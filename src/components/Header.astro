---
import { localizePath, getLocaleFromPath } from "@/i18n";

const locale = getLocaleFromPath(Astro.url.pathname);
---

<a id="skip-to-content" href="#main-content" class="skip-link">
  Skip to content
</a>

<div
  class="sticky top-0 z-30 flex h-16 w-full justify-center bg-base-100/90 text-base-content shadow-sm backdrop-blur transition-all duration-100 lg:hidden"
>
  <div class="navbar">
    <div class="navbar-start">
      <label for="site-drawer" class="btn btn-square btn-ghost">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          fill="none"
          viewBox="0 0 24 24"
          class="inline-block h-5 w-5 stroke-current"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </label>
    </div>
    <div class="navbar-center">
      <a
        class="btn text-xl font-semibold normal-case btn-ghost"
        href={localizePath("/", locale)}
      >
        Meng Lei
      </a>
    </div>
    <div class="navbar-end"></div>
  </div>
</div>
