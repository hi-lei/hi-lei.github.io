---
import IconHash from "@/assets/icons/IconHash.svg";
import { getLocaleFromPath, localizePath } from "@/i18n";

type Props = {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
};

const { tag, tagName, size = "lg" } = Astro.props;
const locale = getLocaleFromPath(Astro.url.pathname);
---

<li>
  <a
    href={localizePath(`/tags/${tag}/`, locale)}
    transition:name={tag}
    class:list={[
      "badge gap-1 border-base-300 bg-base-100 py-4",
      { "badge-sm": size === "sm" },
      { "badge-lg": size === "lg" },
    ]}
  >
    <IconHash
      class:list={[{ "size-4": size === "lg" }, { "size-3.5": size === "sm" }]}
    />
    {tagName}
  </a>
</li>
