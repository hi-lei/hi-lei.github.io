---
import type { Page } from "astro";
import type { CollectionEntry } from "astro:content";
import IconArrowLeft from "@/assets/icons/IconArrowLeft.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { getLocaleFromPath, t } from "@/i18n";
import LinkButton from "./LinkButton.astro";

type Props = {
  page: Page<CollectionEntry<"blog">>;
};

const { page } = Astro.props;
const locale = getLocaleFromPath(Astro.url.pathname);
const copy = t(locale);
---

{
  page.lastPage > 1 && (
    <nav
      class="pagination-shell"
      role="navigation"
      aria-label="Pagination Navigation"
    >
      <LinkButton
        disabled={!page.url.prev}
        href={page.url.prev as string}
        class:list={[
          "pagination-chip me-4 select-none",
          { "opacity-50": !page.url.prev },
        ]}
        aria-label="Goto Previous Page"
      >
        <IconArrowLeft class="inline-block rtl:rotate-180" />
        {copy.pages.prev}
      </LinkButton>
      <span class="inline-flex items-center text-sm text-foreground-soft">
        {page.currentPage} / {page.lastPage}
      </span>
      <LinkButton
        disabled={!page.url.next}
        href={page.url.next as string}
        class:list={[
          "pagination-chip ms-4 select-none",
          { "opacity-50": !page.url.next },
        ]}
        aria-label="Goto Next Page"
      >
        {copy.pages.next}
        <IconArrowRight class="inline-block rtl:rotate-180" />
      </LinkButton>
    </nav>
  )
}
